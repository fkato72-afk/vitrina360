# Copia a  deploy/.env  y completa. NO lo subas al repo (permisos 600).
# Lo usan docker compose (sustitucion ${VAR}) y los contenedores (env_file).
# IMPORTANTE: sin comentarios en la misma linea del valor (compose los toma como parte del valor).

# ── App / Claude ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VITRINA_MODEL=claude-sonnet-4-6
# id del modelo semantico ULima360 (lo provees en el .env real del despliegue)
VITRINA_DATASET_ID=<dataset-id-de-ULima360>
# id del workspace (grupo) — REQUERIDO para el SP: executeQueries usa /groups/{ws}/...
VITRINA_WORKSPACE_ID=<workspace-id-de-ULima-DataLake>
# volumen persistente de auditoria (ver compose)
VITRINA_AUDIT_PATH=/app/audit/audit.log.jsonl

# ── Service principal: lee ULima360 read-only (Entra ID app #1) ───────────────
FABRIC_TENANT_ID=<tenant-guid>
FABRIC_SP_CLIENT_ID=<client-id-del-SP>
FABRIC_SP_CLIENT_SECRET=<client-secret-del-SP>

# ── Host publico (DNS A -> IP de la VM) ───────────────────────────────────────
VITRINA_HOST=vitrina360.ulima.edu.pe

# ── SSO Entra ID para usuarios (oauth2-proxy; Entra ID app #2) ────────────────
OAUTH2_PROXY_CLIENT_ID=<client-id-de-la-app-OIDC>
OAUTH2_PROXY_CLIENT_SECRET=<client-secret-de-la-app-OIDC>
# generar con:  openssl rand -base64 32   (o lo genera deploy.sh)
OAUTH2_PROXY_COOKIE_SECRET=
# restringe el acceso a correos @ulima.edu.pe
OAUTH2_PROXY_EMAIL_DOMAIN=ulima.edu.pe

# ── Email para el certificado Let's Encrypt (lo usa deploy.sh) ────────────────
CERTBOT_EMAIL=<correo-para-avisos-del-certificado>
