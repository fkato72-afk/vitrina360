# ENV del proyecto en Hostinger (Manage -> Environment). NO va al repo.
# Compose lo usa para sustituir ${VAR} en hostinger.compose.yml.

# --- ids (no son secretos, pero se inyectan aqui para no quemarlos en el repo) ---
VITRINA_DATASET_ID=<dataset-id-de-ULima360>
FABRIC_TENANT_ID=<tenant-guid>
FABRIC_SP_CLIENT_ID=<client-id-del-SP>

# --- secretos reales (pegar el VALUE, nunca el Secret ID) ---
FABRIC_SP_CLIENT_SECRET=<client-secret-del-SP>
ANTHROPIC_API_KEY=sk-ant-...

# --- gate de prueba: htpasswd  (genera con:  openssl passwd -apr1 'tu-clave') ---
# formato:  usuario:hash   (un solo $ aqui; Traefik lo recibe tal cual)
BASIC_AUTH_USERS=ulima:<hash-apr1>
