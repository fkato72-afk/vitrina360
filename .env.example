# Copia a .env y completa. El backend lee estas variables del entorno.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo para NL->spec (rapido y barato; sube a opus para preguntas complejas)
VITRINA_MODEL=claude-sonnet-4-6
# Secreto para firmar la sesion (genera uno: python -c "import secrets;print(secrets.token_hex(32))")
VITRINA_JWT_SECRET=cambia-esto
VITRINA_COOKIE_SECURE=1
